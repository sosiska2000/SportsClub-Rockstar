<Page x:Class="Rockstar.Admin.WPF.Views.Trainers.AddTrainerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="600"
      Background="#F5F7FA"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#2C2C2E"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>

        <Style x:Key="FormInputStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E8E8ED"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FF4D00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E64500"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E8E8ED"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#FF4D00"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding PageTitle}" 
                       FontSize="24" FontWeight="SemiBold" Foreground="#2C2C2E"/>
            <TextBlock Text="Заполните данные тренера" 
                       FontSize="14" Foreground="#8E8E93" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,24,0,0">
            <StackPanel>
                <!-- Фото -->
                <TextBlock Text="Фотография" Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormInputStyle}" Height="120" Cursor="Hand"
                        MouseLeftButtonDown="PhotoBorder_MouseDown">
                    <Grid>
                        <Image x:Name="PhotoImage" 
                               Source="{Binding PhotoPreview}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Нажмите для загрузки" 
                                   Foreground="#8E8E93"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding PhotoVisibility}"/>
                    </Grid>
                </Border>

                <!-- Имя и Фамилия -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Имя" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource FormInputStyle}">
                            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" FontSize="14"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding FirstNameError}" Style="{StaticResource ErrorTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Фамилия" Style="{StaticResource FormLabelStyle}"/>
                        <Border Style="{StaticResource FormInputStyle}">
                            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" FontSize="14"
                                     VerticalContentAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding LastNameError}" Style="{StaticResource ErrorTextStyle}"/>
                    </StackPanel>
                </Grid>

                <!-- Направление -->
                <TextBlock Text="Направление" Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormInputStyle}">
                    <ComboBox ItemsSource="{Binding Directions}"
                              SelectedItem="{Binding SelectedDirection}"
                              DisplayMemberPath="Value"
                              SelectedValuePath="Key"
                              BorderThickness="0" Background="Transparent" FontSize="14"
                              VerticalContentAlignment="Center"/>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email (логин)" Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormInputStyle}">
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent" FontSize="14"
                             VerticalContentAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding EmailError}" Style="{StaticResource ErrorTextStyle}"/>

                <!-- Пароль -->
                <TextBlock Text="Пароль" Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormInputStyle}">
                    <PasswordBox x:Name="PasswordBox"
                                 BorderThickness="0" Background="Transparent" FontSize="14"
                                 VerticalContentAlignment="Center"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </Border>
                <TextBlock Text="{Binding PasswordError}" Style="{StaticResource ErrorTextStyle}"/>

                <!-- Стаж -->
                <TextBlock Text="Стаж работы (лет)" Style="{StaticResource FormLabelStyle}"/>
                <Border Style="{StaticResource FormInputStyle}">
                    <TextBox Text="{Binding Experience, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent" FontSize="14"
                             VerticalContentAlignment="Center"
                             PreviewTextInput="NumberValidationTextBox"/>
                </Border>

                <!-- Описание -->
                <TextBlock Text="Описание" Style="{StaticResource FormLabelStyle}"/>
                <Border CornerRadius="8" Background="White" BorderThickness="1" BorderBrush="#E8E8ED"
                        Padding="12" MinHeight="100">
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent" FontSize="14"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Отмена" Style="{StaticResource SecondaryButtonStyle}"
                    Width="140" Margin="0,0,12,0" Command="{Binding CancelCommand}"/>
            <Button Content="{Binding SaveButtonText}" Style="{StaticResource PrimaryButtonStyle}"
                    Width="140" Command="{Binding SaveCommand}" IsEnabled="{Binding CanSave}"/>
        </StackPanel>
    </Grid>
</Page>