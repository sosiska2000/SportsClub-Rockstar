<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Верхняя панель -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_gradient_small"
        android:padding="12dp">

        <ImageButton
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@android:color/transparent"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ТРЕНЕРЫ"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <!-- Фильтр по направлениям -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        android:paddingStart="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnAll"
                style="@style/DateButton"
                android:text="Все"
                android:background="@drawable/btn_primary_small"
                android:textColor="@android:color/white"/>

            <Button
                android:id="@+id/btnYoga"
                style="@style/DateButton"
                android:text="Йога"
                android:background="@drawable/btn_outline_small"
                android:textColor="@color/text_secondary"/>

            <Button
                android:id="@+id/btnFitness"
                style="@style/DateButton"
                android:text="Фитнес"
                android:background="@drawable/btn_outline_small"
                android:textColor="@color/text_secondary"/>

            <Button
                android:id="@+id/btnClimbing"
                style="@style/DateButton"
                android:text="Скалолазание"
                android:background="@drawable/btn_outline_small"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Прогресс бар -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:visibility="gone"/>

    <!-- Пустое состояние -->
    <LinearLayout
        android:id="@+id/llEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_empty"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нет тренеров"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Обновить"
            android:background="@drawable/btn_outline_small"
            android:textColor="@color/primary"
            android:paddingHorizontal="24dp"/>
    </LinearLayout>

    <!-- Список тренеров -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTrainers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"
        android:visibility="gone"/>

</LinearLayout>