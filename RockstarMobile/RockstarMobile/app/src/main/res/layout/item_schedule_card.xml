<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSchedule"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Время -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvScheduleTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FF4D00"/>

        </LinearLayout>

        <!-- Информация -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvScheduleDirection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Йога"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2C2C2E"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvScheduleService"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Хатха-йога"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvScheduleTrainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Анна Соколова"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSchedulePrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="600 ₽"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FF4D00"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/tvScheduleParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5/15"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvScheduleAvailable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Свободно: 10"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>