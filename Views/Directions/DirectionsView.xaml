<Page x:Class="Rockstar.Admin.WPF.Views.Directions.DirectionsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="750" d:DesignWidth="1100"
      Background="#F5F7FA"
      FontFamily="Segoe UI">

    <Page.Resources>
        <Style x:Key="PageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C2C2E"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="DirectionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C2C2E"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="#E8E8ED">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF5F0"/>
                                <Setter Property="BorderBrush" Value="#FF4D00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DirectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#8E8E93"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Виды направлений" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Выберите направление для просмотра и управления услугами" 
                       FontSize="14" Foreground="#8E8E93" Margin="0,4,0,32"/>
        </StackPanel>

        <!-- Кнопки направлений -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Йога"
                    Style="{StaticResource DirectionButtonStyle}"
                    Command="{Binding NavigateToYogaCommand}"/>

            <TextBlock Text="Практики для гармонии тела и духа"
                       Style="{StaticResource DirectionDescriptionStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Button Content="Фитнес"
                    Style="{StaticResource DirectionButtonStyle}"
                    Command="{Binding NavigateToFitnessCommand}"/>

            <TextBlock Text="Тренажерный зал и групповые тренировки"
                       Style="{StaticResource DirectionDescriptionStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Button Content="Скалолазание"
                    Style="{StaticResource DirectionButtonStyle}"
                    Command="{Binding NavigateToClimbingCommand}"/>

            <TextBlock Text="Скалодром для всех уровней подготовки"
                       Style="{StaticResource DirectionDescriptionStyle}"
                       HorizontalAlignment="Center"/>
            <Button Content="Назад"
        Style="{StaticResource DirectionButtonStyle}" Click="backbutton_click"/>
        </StackPanel>
    </Grid>
</Page>