<Page x:Class="Rockstar.Admin.WPF.Views.Auth.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F5F7FA" Height="646" Width="517">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" HorizontalAlignment="Center" Width="420">

                <!-- Логотип -->
                <TextBlock Text="РОКСТАР" 
                           FontSize="28" FontWeight="Bold"
                           Foreground="#FF4D00"
                           HorizontalAlignment="Center"
                           Margin="0,30,0,8"/>
                <TextBlock Text="Спортивный клуб" 
                           FontSize="14"
                           Foreground="#8E8E93"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- Форма входа -->
                <Border Background="White" 
                        CornerRadius="12" 
                        Padding="24">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" Direction="270" ShadowDepth="4"/>
                    </Border.Effect>

                    <StackPanel>

                        <!-- Email -->
                        <TextBlock Text="Email" FontSize="14" Foreground="#2C2C2E" Margin="0,0,0,5"/>
                        <Border CornerRadius="8" Background="White" BorderThickness="1" BorderBrush="#E8E8ED" Height="48" Padding="12,0">
                            <TextBox x:Name="EmailTextBox" 
                                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Пароль -->
                        <TextBlock Text="Пароль" FontSize="14" Foreground="#2C2C2E" Margin="0,15,0,5"/>
                        <Border CornerRadius="8" Background="White" BorderThickness="1" BorderBrush="#E8E8ED" Height="48" Padding="12,0">
                            <PasswordBox x:Name="PasswordBox" 
                                         BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Сообщение об ошибке -->
                        <TextBlock Text="{Binding ErrorMessage}"
                                   FontSize="12" Foreground="#FF4D00" TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="{Binding IsErrorVisible}"/>

                        <!-- Кнопка входа -->
                        <Button Content="Войти" 
                                Background="#FF4D00" Foreground="White"
                                FontSize="14" FontWeight="Medium" Height="48" BorderThickness="0"
                                Cursor="Hand" Margin="0,25,0,10"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding CanLogin}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E64500"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Индикатор загрузки -->
                        <ProgressBar IsIndeterminate="True" Height="3" Foreground="#FF4D00" Background="Transparent"
                                     Visibility="{Binding IsLoadingVisible}" Margin="0,0,0,15"/>

                        <!-- Разделитель -->
                        <StackPanel Orientation="Horizontal" Margin="0,10" HorizontalAlignment="Center">
                            <Rectangle Height="1" Fill="#E8E8ED" Width="140"/>
                            <TextBlock Text="или" Foreground="#8E8E93" Margin="12,0" VerticalAlignment="Center"/>
                            <Rectangle Height="1" Fill="#E8E8ED" Width="140"/>
                        </StackPanel>

                        <!-- Кнопка восстановления -->
                        <Button Content="Забыли пароль?" 
                                Background="Transparent" Foreground="#FF4D00"
                                FontSize="14" FontWeight="Medium" Height="40" BorderThickness="0"
                                Cursor="Hand" HorizontalAlignment="Center"
                                Command="{Binding ForgotPasswordCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Футер -->
                <TextBlock Text="© 2026 Спортивный клуб «Рокстар»"
                           FontSize="11" Foreground="#8E8E93"
                           HorizontalAlignment="Center" Margin="0,30,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>