<UserControl x:Class="Rockstar.Admin.WPF.Views.Trainers.Controls.TrainerCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="280">

    <UserControl.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E8E8ED"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="12" Direction="270" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF4D00"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF5F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DirectionBadgeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#FFF5F0"/>
            <Setter Property="Foreground" Value="#FF4D00"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorderStyle}" Width="280">
        <StackPanel>
            <!-- Фото -->
            <Border Width="120" Height="120" 
                    Background="#F5F7FA" 
                    CornerRadius="60" 
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12"
                    ClipToBounds="True">
                <Image Source="{Binding PhotoSource}"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Имя -->
            <TextBlock Text="{Binding FullName}"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="#2C2C2E"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>

            <!-- Направление -->
            <TextBlock Text="{Binding DirectionDisplayName}"
                       Style="{StaticResource DirectionBadgeStyle}"
                       Margin="0,8,0,0"/>

            <!-- Стаж -->
            <TextBlock Text="{Binding ExperienceText}"
                       FontSize="13" Foreground="#8E8E93"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

            <!-- Описание -->
            <TextBlock Text="{Binding Description}"
                       FontSize="13" Foreground="#666666"
                       TextWrapping="Wrap"
                       MaxHeight="60"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,12,0,0"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,16,0,0">
                <Button Content="Редактировать"
                        Style="{StaticResource CardButtonStyle}"
                        Command="{Binding EditCommand}"
                        Margin="0,0,8,0"/>
                <Button Content="Удалить"
                        Style="{StaticResource CardButtonStyle}"
                        Foreground="#FF5252"
                        Command="{Binding DeleteCommand}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>