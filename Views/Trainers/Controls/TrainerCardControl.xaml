<UserControl x:Class="Rockstar.Admin.WPF.Views.Trainers.Controls.TrainerCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="350"
             x:Name="CardControl">

    <UserControl.Resources>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF4D00"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFF5F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White" 
            CornerRadius="12" 
            BorderThickness="1" 
            BorderBrush="#E8E8ED"
            Padding="0"
            Margin="8"
            Width="350">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" Direction="270" ShadowDepth="4"/>
        </Border.Effect>

        <StackPanel>
            <!-- Фото тренера -->
            <Border Height="300" 
                    Background="#F5F7FA"
                    ClipToBounds="True">
                <Image Source="{Binding PhotoSource, ElementName=CardControl}"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Border>

            <!-- Информация о тренере -->
            <StackPanel Margin="20,16,20,16">
                <!-- Имя -->
                <TextBlock Text="{Binding FullName, ElementName=CardControl}"
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="#2C2C2E"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Направление -->
                <TextBlock Text="{Binding DirectionDisplayName, ElementName=CardControl}"
                           FontSize="13" 
                           Foreground="#8E8E93"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <!-- Стаж -->
                <TextBlock Text="{Binding ExperienceText, ElementName=CardControl}"
                           FontSize="13" 
                           Foreground="#8E8E93"
                           Margin="0,0,0,12"/>

                <!-- Описание -->
                <TextBlock Text="{Binding Description, ElementName=CardControl}"
                           FontSize="13" 
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           LineHeight="18"
                           Margin="0,0,0,16"/>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Left">
                    <Button Content="Редактировать"
                            Style="{StaticResource CardButtonStyle}"
                            Command="{Binding EditCommand, ElementName=CardControl}"
                            CommandParameter="{Binding Trainer, ElementName=CardControl}"
                            Margin="0,0,12,0"/>
                    <Button Content="Удалить"
                            Style="{StaticResource CardButtonStyle}"
                            Foreground="#FF5252"
                            Command="{Binding DeleteCommand, ElementName=CardControl}"
                            CommandParameter="{Binding Trainer, ElementName=CardControl}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>